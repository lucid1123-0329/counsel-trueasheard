{
  "version": 2,
  "headers": [
    {
      "source": "/(admin|admin.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/favicon-32.png",
      "dest": "/public/favicon-32.png"
    },
    {
      "src": "/apple-touch-icon.png",
      "dest": "/public/apple-touch-icon.png"
    },
    {
      "src": "/og-mbhj-v2.png",
      "dest": "/public/og-mbhj-v2.png"
    },
    {
      "src": "/api/gs",
      "dest": "/api/gs.js"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}